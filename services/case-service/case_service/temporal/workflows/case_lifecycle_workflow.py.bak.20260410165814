from __future__ import annotations

import dataclasses
from datetime import timedelta
from typing import Any

from temporalio import workflow

with workflow.unsafe.imports_passed_through():
    from case_service.temporal.activities.stage_activities import (
        create_stage_assignments,
        evaluate_exit_criteria,
        load_case_type_definition,
        update_case_stage,
        update_case_status,
    )
    from case_service.temporal.activities.sla_activities import (
        start_sla_tracking,
    )
    from case_service.temporal.activities.notification_activities import (
        send_case_notification,
    )


# ─── Workflow params / result ─────────────────────────────────────────


@dataclasses.dataclass
class CaseLifecycleParams:
    case_id: str
    case_type_id: str


@dataclasses.dataclass
class CaseLifecycleResult:
    case_id: str
    final_status: str


@dataclasses.dataclass
class StepCompletedSignal:
    step_id: str
    result: dict[str, Any] = dataclasses.field(default_factory=dict)


@dataclasses.dataclass
class StatusChangeSignal:
    new_status: str
    reason: str | None = None
    actor_id: str | None = None


@dataclasses.dataclass
class StageTransitionSignal:
    target_stage_id: str
    actor_id: str | None = None


@dataclasses.dataclass
class SLABreachedSignal:
    sla_policy_id: str


# ─── Workflow ─────────────────────────────────────────────────────────

ACTIVITY_TIMEOUT = timedelta(seconds=30)


@workflow.defn
class CaseLifecycleWorkflow:
    """Drives a single case through its stage-based lifecycle.

    Signals:
        step_completed    — a work item has been finished
        status_changed    — external status change request
        stage_transition  — explicit stage move
        sla_breached      — child SLA workflow reports a breach
    """

    def __init__(self) -> None:
        self._case_id: str = ""
        self._status: str = "new"
        self._current_stage_id: str | None = None
        self._completed_steps: set[str] = set()
        self._pending_signals: list[StepCompletedSignal] = []
        self._force_stage: str | None = None
        self._cancel_requested: bool = False

    # ── Signals ───────────────────────────────────────────────────

    @workflow.signal
    async def step_completed(self, signal: StepCompletedSignal) -> None:
        self._completed_steps.add(signal.step_id)
        self._pending_signals.append(signal)

    @workflow.signal
    async def status_changed(self, signal: StatusChangeSignal) -> None:
        self._status = signal.new_status
        if signal.new_status == "cancelled":
            self._cancel_requested = True

    @workflow.signal
    async def stage_transition(
        self, signal: StageTransitionSignal
    ) -> None:
        self._force_stage = signal.target_stage_id

    @workflow.signal
    async def sla_breached(self, signal: SLABreachedSignal) -> None:
        # Escalation is handled by the SLA timer workflow's activities.
        # Here we just log awareness — could trigger further actions.
        workflow.logger.warning(
            "SLA breached for policy %s on case %s",
            signal.sla_policy_id,
            self._case_id,
        )

    # ── Queries ───────────────────────────────────────────────────

    @workflow.query
    def get_state(self) -> dict[str, Any]:
        return {
            "case_id": self._case_id,
            "status": self._status,
            "current_stage_id": self._current_stage_id,
            "completed_steps": list(self._completed_steps),
        }

    # ── Main run ──────────────────────────────────────────────────

    @workflow.run
    async def run(
        self, params: CaseLifecycleParams
    ) -> CaseLifecycleResult:
        self._case_id = params.case_id

        # 1. Load the case type definition (stages, steps, SLAs)
        case_type_def = await workflow.execute_activity(
            load_case_type_definition,
            params.case_type_id,
            start_to_close_timeout=ACTIVITY_TIMEOUT,
        )

        # 2. Set status to OPEN
        self._status = "open"
        await workflow.execute_activity(
            update_case_status,
            args=[params.case_id, "open"],
            start_to_close_timeout=ACTIVITY_TIMEOUT,
        )

        # 3. Start case-level SLAs
        case_sla_ids: list[str] = case_type_def.get(
            "case_sla_policy_ids", []
        )
        for sla_id in case_sla_ids:
            await workflow.execute_activity(
                start_sla_tracking,
                args=[params.case_id, sla_id, params.case_id],
                start_to_close_timeout=ACTIVITY_TIMEOUT,
            )

        # 4. Walk through stages in order
        stages = case_type_def.get("stages", [])
        for stage in stages:
            if self._cancel_requested:
                break

            # Check for forced stage transition
            if (
                self._force_stage
                and self._force_stage != stage["id"]
            ):
                continue
            self._force_stage = None

            await self._execute_stage(params.case_id, stage)

            if self._status in ("cancelled", "closed"):
                break

        # 5. Resolve if we completed all stages
        if self._status == "open":
            self._status = "resolved"
            await workflow.execute_activity(
                update_case_status,
                args=[params.case_id, "resolved"],
                start_to_close_timeout=ACTIVITY_TIMEOUT,
            )

        await workflow.execute_activity(
            send_case_notification,
            args=[
                params.case_id,
                f"case_{self._status}",
                {"status": self._status},
            ],
            start_to_close_timeout=ACTIVITY_TIMEOUT,
        )

        return CaseLifecycleResult(
            case_id=params.case_id,
            final_status=self._status,
        )

    # ── Stage execution ───────────────────────────────────────────

    async def _execute_stage(
        self, case_id: str, stage: dict[str, Any]
    ) -> None:
        stage_id = stage["id"]
        self._current_stage_id = stage_id

        await workflow.execute_activity(
            update_case_stage,
            args=[case_id, stage_id],
            start_to_close_timeout=ACTIVITY_TIMEOUT,
        )

        # Start stage-level SLA if configured
        sla_policy_id = stage.get("sla_policy_id")
        if sla_policy_id:
            await workflow.execute_activity(
                start_sla_tracking,
                args=[case_id, sla_policy_id, stage_id],
                start_to_close_timeout=ACTIVITY_TIMEOUT,
            )

        # Create assignments for all steps in this stage
        steps = stage.get("steps", [])
        step_ids = {s["id"] for s in steps}
        required_step_ids = {
            s["id"] for s in steps if s.get("required", True)
        }

        await workflow.execute_activity(
            create_stage_assignments,
            args=[case_id, stage_id, steps],
            start_to_close_timeout=ACTIVITY_TIMEOUT,
        )

        # Wait for required steps to complete
        while not required_step_ids.issubset(self._completed_steps):
            if self._cancel_requested or self._force_stage:
                break
            await workflow.wait_condition(
                lambda: (
                    bool(self._pending_signals)
                    or self._cancel_requested
                    or self._force_stage is not None
                )
            )
            self._pending_signals.clear()

        # Evaluate exit criteria
        if not self._cancel_requested and not self._force_stage:
            await workflow.execute_activity(
                evaluate_exit_criteria,
                args=[case_id, stage_id],
                start_to_close_timeout=ACTIVITY_TIMEOUT,
            )
