# Velaris — environment variables
#
# HOW TO USE:
#   setup-velaris.sh creates .env automatically on first run.
#   You only need to edit this for AI provider keys and optional overrides.
#   Never commit .env — only .env.example belongs in git.
#
#   Commented variables show their built-in default — uncomment to override.

# ════════════════════════════════════════════════════════════════════
#  INFRASTRUCTURE — auto-generated by setup-velaris.sh
#  Do not set these manually; let the setup script generate them.
# ════════════════════════════════════════════════════════════════════

# Shared password for PostgreSQL (helix-db), Keycloak (KC_DB), and MinIO.
# Auto-generated as a random 32-char hex string during setup.
VELARIS_DB_PASSWORD=

# Keycloak admin console password (separate from the DB password).
# Auto-generated during setup.
VELARIS_ADMIN_PASSWORD=

# OpenSearch admin password (only relevant if the search profile is enabled).
VELARIS_SEARCH_PASSWORD=

# Also auto-generated into .env by setup-velaris.sh (listed for reference):
#   HELIX_CASE_AUTH_SECRET           — JWT fallback secret (random hex)
#   HELIX_CASE_STORAGE_MASTER_KEY    — AES-256-GCM key for documents at rest
#   HELIX_CASE_AUTH_RSA_PRIVATE_KEY  — RS256 signing key (PEM, \n-escaped)
#   HELIX_CASE_AUTH_RSA_PUBLIC_KEY   — RS256 verification key (PEM, \n-escaped)

# ════════════════════════════════════════════════════════════════════
#  MUST SET IN PRODUCTION — these have insecure defaults
# ════════════════════════════════════════════════════════════════════

# JWT signing secret — setup-velaris.sh generates a random one when empty.
# Generate manually: openssl rand -hex 32
# Left empty/unset, the code falls back to a known dev string and prints a
# SECURITY WARNING at startup. (RS256 keys, when set, take precedence anyway.)
HELIX_CASE_AUTH_SECRET=

# Database — populated from VELARIS_DB_PASSWORD by setup-velaris.sh
HELIX_CASE_DATABASE_URL=postgresql+asyncpg://helix:REPLACE@localhost:5432/helix

# Document storage path. setup-velaris.sh provisions <install-dir>/data/documents
# and sets this automatically. Override here only to point elsewhere.
# VELARIS_CASE_STORAGE_LOCAL_PATH=/path/to/documents

# ════════════════════════════════════════════════════════════════════
#  AUTH & TOKENS
# ════════════════════════════════════════════════════════════════════

# Access tokens are short-lived; refresh tokens rotate on every use.
# HELIX_CASE_ACCESS_TOKEN_EXPIRY_MINUTES=15
# Refresh token lifetime in days (also overridable in the admin settings UI).
# HELIX_CASE_TOKEN_EXPIRY_DAYS=60

# Auth mode: "jwt" (default) or "oidc" (external IdP).
# HELIX_CASE_AUTH_MODE=jwt
# HELIX_CASE_AUTH_ISSUER=helix
# HELIX_CASE_AUTH_AUDIENCE=helix-api
# HELIX_CASE_OIDC_DISCOVERY_URL=
# HELIX_CASE_OIDC_CLIENT_ID=helix-studio

# ════════════════════════════════════════════════════════════════════
#  SECURITY — REQUEST BODY SIZE LIMITS (Group D, values in bytes)
# ════════════════════════════════════════════════════════════════════

# JSON payloads — 10 MB default.
# HELIX_CASE_MAX_BODY_BYTES=10485760
# Multipart file uploads (documents, portal, HxNexus, importer) — 25 MB default.
# HELIX_CASE_MAX_UPLOAD_BYTES=26214400
# HxMigrate BPM vendor exports only — 200 MB transport cap
# (hxmigrate's SEC-7 still enforces 100 MB per file inside the request).
# HELIX_CASE_MAX_MIGRATE_UPLOAD_BYTES=209715200

# ════════════════════════════════════════════════════════════════════
#  DATABASE CONNECTION POOLS (Group C)
#  Three isolated pools: operations / auth / analytics.
#  Exhausting one pool can never starve the others.
# ════════════════════════════════════════════════════════════════════

# Operations pool — case CRUD, forms, general endpoints.
# HELIX_CASE_DB_POOL_SIZE=10
# HELIX_CASE_DB_MAX_OVERFLOW=5
# Dedicated auth pool — login, refresh, token checks.
# HELIX_CASE_DB_AUTH_POOL_SIZE=3
# Analytics pool — reporting, compliance, sync, sitemap.
# HELIX_CASE_DB_ANALYTICS_POOL_SIZE=3
# Echo SQL statements to the log (debug only — very verbose).
# HELIX_CASE_DB_ECHO=false
#
# Read-only replica (hot standby) for HEAVY ANALYTICS QUERIES only —
# dashboard, metrics, OData feed. Compliance/sync/PUO and anything that
# writes always stay on the primary. Empty = analytics queries use the
# primary too. (Group I)
# HELIX_CASE_DB_ANALYTICS_URL=postgresql+asyncpg://helix:pass@replica-host:5432/helix

# ── Webhooks (Group I) — thin events ──
# Webhook payloads carry IDs + status only; set true to embed full case
# variables in outbox payloads (legacy consumers only).
# HELIX_CASE_WEBHOOK_FULL_PAYLOADS=false

# ── Audit chain external anchoring (Group I) — RFC-3161 ──
# A timestamp authority signs the audit-chain tip daily, making history
# externally provable. Default TSA is freetsa.org; any RFC-3161 TSA works.
# HELIX_CASE_AUDIT_ANCHOR_ENABLED=true
# HELIX_CASE_AUDIT_TSA_URL=https://freetsa.org/tsr
# HELIX_CASE_AUDIT_ANCHOR_INTERVAL_HOURS=24

# ── WebAuthn / passkeys (Group J) ──
# rp_id must be the registrable domain the app is served from; origin must
# match the browser origin EXACTLY (scheme + host + port) or every passkey
# ceremony fails verification. Production example: rp_id=velaris.example.com,
# origin=https://velaris.example.com
# HELIX_CASE_WEBAUTHN_RP_ID=localhost
# HELIX_CASE_WEBAUTHN_RP_NAME=Velaris
# HELIX_CASE_WEBAUTHN_ORIGIN=http://localhost:5173

# ════════════════════════════════════════════════════════════════════
#  UNIFIED AI BACKEND
#  Used by ALL AI features: HxNexus, NLP Builder, Scout AI, BPM Importer.
# ════════════════════════════════════════════════════════════════════
#
# ── AI egress policy (Group E) — controls what may leave the platform ──
#   local_only — external AI providers refused; local Ollama used instead
#   minimized  — external completions allowed, embeddings ALWAYS stay local
#                (document content never leaves the platform at index time)
#   full       — external provider used as-is (explicit opt-in)
# Note: switching an externally-indexed deployment to "minimized" requires
# re-indexing documents (embedding spaces are not comparable).
HELIX_CASE_AI_EGRESS_POLICY=minimized
#
# Chunk minimization when completions go to an external provider (Group H):
# HELIX_CASE_AI_EGRESS_TOP_K=3
# HELIX_CASE_AI_EGRESS_MIN_SCORE=0.25
# HELIX_CASE_AI_EGRESS_MAX_CONTEXT_CHARS=6000
#
# ══════════════════════════════════════════════════════════════════
#  SIMPLE (recommended) — set only these 3-4 vars for ANY provider.
#  The system auto-resolves the API endpoint. Zero code changes needed.
# ══════════════════════════════════════════════════════════════════
#
#  Supported values for HELIX_CASE_AI_PROVIDER:
#    ollama      — local, free, no API key needed (default)
#    openai      — OpenAI (GPT-4o, GPT-4o-mini, etc.)
#    anthropic   — Anthropic (Claude) — uses native Anthropic SDK
#    groq        — Groq (fastest inference, llama/mixtral models)
#    mistral     — Mistral AI
#    gemini      — Google Gemini (via OpenAI-compatible endpoint)
#    together    — Together AI (llama, qwen, etc.)
#    fireworks   — Fireworks AI
#    perplexity  — Perplexity AI
#    deepseek    — DeepSeek
#    xai         — xAI (Grok)
#    cohere      — Cohere
#    custom      — any OpenAI-compatible API (set HELIX_CASE_AI_BASE_URL too;
#                  a localhost BASE_URL counts as local for the egress policy)
#
HELIX_CASE_AI_PROVIDER=ollama
HELIX_CASE_AI_API_KEY=
HELIX_CASE_AI_MODEL=
HELIX_CASE_AI_EMBED_MODEL=
HELIX_CASE_AI_BASE_URL=
#
# Examples:
#   Groq:    PROVIDER=groq   API_KEY=gsk_xxx  MODEL=llama-3.1-70b-versatile
#   Gemini:  PROVIDER=gemini API_KEY=xxx      MODEL=gemini-1.5-flash
#   Mistral: PROVIDER=mistral API_KEY=xxx     MODEL=mistral-large-latest
#   Custom:  PROVIDER=custom  API_KEY=xxx     MODEL=my-model  BASE_URL=https://my-server/v1
#
# ══════════════════════════════════════════════════════════════════
#  LEGACY vars — still work, used as fallback when PROVIDER is not set
# ══════════════════════════════════════════════════════════════════
HELIX_CASE_AI_BACKEND=ollama

# --- Ollama (default — runs locally via Docker, no API key needed) ---
# To use a custom GGUF model: place the .gguf file in the repo-root models/ folder,
# then set HELIX_CASE_AI_OLLAMA_MODEL to the filename without extension.
# Example: models/mistral-7b-q4.gguf  →  HELIX_CASE_AI_OLLAMA_MODEL=mistral-7b-q4
HELIX_CASE_AI_OLLAMA_URL=http://localhost:11434
HELIX_CASE_AI_OLLAMA_MODEL=llama3.2
HELIX_CASE_AI_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- OpenAI ---
HELIX_CASE_AI_OPENAI_API_KEY=
HELIX_CASE_AI_OPENAI_MODEL=gpt-4o-mini
HELIX_CASE_AI_OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic ---
HELIX_CASE_AI_ANTHROPIC_API_KEY=
HELIX_CASE_AI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- NLP case generation ---
# HELIX_CASE_NLP_ENABLED=true
# Use heuristic fallback when the LLM is unavailable.
# HELIX_CASE_NLP_FALLBACK_ENABLED=true

# ════════════════════════════════════════════════════════════════════
#  SERVICE RUNTIME
# ════════════════════════════════════════════════════════════════════

# HELIX_CASE_SERVICE_NAME=helix-case-service
# HELIX_CASE_SERVICE_HOST=0.0.0.0
# HELIX_CASE_SERVICE_PORT=8200
# Debug mode relaxes CORS and disables the global rate limiter — never in prod.
# HELIX_CASE_DEBUG=false

# ── Workflow engine ──
# HELIX_CASE_TEMPORAL_HOST=localhost:7233
# HELIX_CASE_TEMPORAL_NAMESPACE=default
# HELIX_CASE_TEMPORAL_TASK_QUEUE=helix-case-queue
# HELIX_CASE_ENGINE_API_URL=http://localhost:8100

# ════════════════════════════════════════════════════════════════════
#  DOCUMENT STORAGE
# ════════════════════════════════════════════════════════════════════

# "local" or "minio". Code default is "local"; setup-velaris.sh writes
# "minio" into .env on fresh installs (MinIO container is part of the stack).
# HELIX_CASE_STORAGE_BACKEND=local
# HELIX_CASE_MINIO_ENDPOINT=localhost:9000
# HELIX_CASE_MINIO_ACCESS_KEY=helix
# HELIX_CASE_MINIO_SECRET_KEY=
# HELIX_CASE_MINIO_BUCKET=helix-docs
# HELIX_CASE_MINIO_SECURE=false

# ════════════════════════════════════════════════════════════════════
#  SCALING — REDIS & RATE LIMITING
# ════════════════════════════════════════════════════════════════════

# Enable Redis for real-time fan-out and the distributed rate limiter.
# HELIX_CASE_REDIS_ENABLED=false
# HELIX_CASE_REDIS_URL=redis://localhost:6379/0
# HELIX_CASE_REDIS_CHANNEL_PREFIX=helix:rt:
# Rate-limit backend: "memory" (single process) or "redis" (multi-worker).
# HELIX_CASE_RATE_LIMIT_BACKEND=memory

# ════════════════════════════════════════════════════════════════════
#  CONNECTOR EXECUTOR LIMITS
# ════════════════════════════════════════════════════════════════════

# HELIX_CASE_CONNECTOR_PAGINATION_DEFAULT_SIZE=50
# Response bodies above this overflow to object storage (bytes).
# HELIX_CASE_CONNECTOR_OVERFLOW_THRESHOLD_BYTES=262144
# Responses above this are rejected and sent to the DLQ (bytes).
# HELIX_CASE_CONNECTOR_HARD_REJECT_BYTES=16777216

# ════════════════════════════════════════════════════════════════════
#  HXMIGRATE CREATOR — enables "Apply to Velaris" in migration runs
# ════════════════════════════════════════════════════════════════════

# Service token for Creator API calls (alternative to user JWT).
# If set alongside a logged-in user JWT, the UI shows a selector.
# Generate: openssl rand -hex 32
# HELIX_SERVICE_TOKEN=

# Override internal service URL if case-service is not on localhost:8200
# HELIX_CASE_SERVICE_URL=http://localhost:8200

# Additional internal hostnames the Creator is allowed to call (comma-separated)
# HELIX_INTERNAL_HOSTS=case-service.internal,api.internal

# ════════════════════════════════════════════════════════════════════
#  PUSH NOTIFICATIONS (P27)
# ════════════════════════════════════════════════════════════════════

# FCM (Firebase Cloud Messaging — Android)
# FCM_SERVICE_ACCOUNT_JSON_PATH=/path/to/firebase-service-account.json
# FCM_SERVICE_ACCOUNT_JSON_CONTENT={}   # alternative: inline JSON

# APNs (Apple Push Notification service — iOS)
# APNS_KEY_PEM=-----BEGIN PRIVATE KEY-----...
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.example.helix
# APNS_SANDBOX=true

# Web Push (VAPID)
# VAPID_PRIVATE_KEY=<base64url DER>
# VAPID_PUBLIC_KEY=<base64url DER>
# VAPID_SUBJECT=mailto:admin@example.com

# ════════════════════════════════════════════════════════════════════
#  EMAIL (P25)
# ════════════════════════════════════════════════════════════════════

# HELIX_CASE_SMTP_HOST=localhost
# HELIX_CASE_SMTP_PORT=1025

# ════════════════════════════════════════════════════════════════════
#  HXMEET — REAL-TIME CASE SESSIONS (P66)
# ════════════════════════════════════════════════════════════════════

# Per-platform default session driver: off_platform (Teams/Zoom/Meet via
# connectors) or embedded (self-hosted LiveKit). Tenants can override.
# VELARIS_CASE_MEET_DRIVER=off_platform

# Embedded driver (LiveKit) — all three required or embedded fail-closes 501.
# Secrets are normally pushed via OpenBao (secrets-push.sh), not set here.
# VELARIS_CASE_LIVEKIT_URL=ws://127.0.0.1:7880
# VELARIS_CASE_LIVEKIT_API_KEY=
# VELARIS_CASE_LIVEKIT_API_SECRET=

# Sealed recordings: shared dir with the livekit-egress container.
# Empty = recording endpoints fail closed with 501.
# VELARIS_CASE_MEET_RECORDINGS_DIR=

# Post-session transcription model (P4a session intelligence, CPU).
# VELARIS_CASE_MEET_WHISPER_MODEL=base

# Live captions (P4a-live): streaming ASR backend — auto probes the machine
# (NVIDIA>CUDA, AMD/Intel GPU>whisper.cpp Vulkan, else CPU lag mode).
# Requires the optional ".[intelligence]" extras (pywhispercpp/faster-whisper).
# VELARIS_CASE_MEET_ASR_BACKEND=auto
# VELARIS_CASE_MEET_ASR_LIVE_MODEL=small
