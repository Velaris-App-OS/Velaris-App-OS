# Velaris — environment variables
#
# HOW TO USE:
#   setup-velaris.sh creates .env automatically on first run.
#   You only need to edit this for AI provider keys and optional overrides.
#   Never commit .env — only .env.example belongs in git.

# ════════════════════════════════════════════════════════════════════
#  INFRASTRUCTURE — auto-generated by setup-velaris.sh
#  Do not set these manually; let the setup script generate them.
# ════════════════════════════════════════════════════════════════════

# Shared password for PostgreSQL (helix-db), Keycloak (KC_DB), and MinIO.
# Auto-generated as a random 32-char hex string during setup.
VELARIS_DB_PASSWORD=

# Keycloak admin console password (separate from the DB password).
# Auto-generated during setup.
VELARIS_ADMIN_PASSWORD=

# OpenSearch admin password (only relevant if the search profile is enabled).
VELARIS_SEARCH_PASSWORD=

# ════════════════════════════════════════════════════════════════════
#  MUST SET IN PRODUCTION — these have insecure defaults
# ════════════════════════════════════════════════════════════════════

# JWT signing secret — REQUIRED in production.
# Generate: openssl rand -hex 32
# Default is a known string that will trigger a SECURITY WARNING at startup.
HELIX_CASE_AUTH_SECRET=helix-dev-secret-change-in-production

# Database — populated from VELARIS_DB_PASSWORD by setup-velaris.sh
HELIX_CASE_DATABASE_URL=postgresql+asyncpg://helix:REPLACE@localhost:5432/helix

# Document storage path — override the default relative path in production
# HELIX_CASE_STORAGE_LOCAL_PATH=/var/lib/helix/documents

# ════════════════════════════════════════════════════════════════════
#  HXMIGRATE CREATOR — enables "Apply to Velaris" in migration runs
# ════════════════════════════════════════════════════════════════════

# Service token for Creator API calls (alternative to user JWT).
# If set alongside a logged-in user JWT, the UI shows a selector.
# Generate: openssl rand -hex 32
# HELIX_SERVICE_TOKEN=

# Override internal service URL if case-service is not on localhost:8200
# HELIX_CASE_SERVICE_URL=http://localhost:8200

# Additional internal hostnames the Creator is allowed to call (comma-separated)
# HELIX_INTERNAL_HOSTS=case-service.internal,api.internal

# ── Unified AI Backend ────────────────────────────────────────────────
# Used by ALL AI features: HxNexus, NLP Builder, Scout AI, BPM Importer.
#
# ══════════════════════════════════════════════════════════════════
#  SIMPLE (recommended) — set only these 3-4 vars for ANY provider.
#  The system auto-resolves the API endpoint. Zero code changes needed.
# ══════════════════════════════════════════════════════════════════
#
#  Supported values for HELIX_CASE_AI_PROVIDER:
#    ollama      — local, free, no API key needed (default)
#    openai      — OpenAI (GPT-4o, GPT-4o-mini, etc.)
#    anthropic   — Anthropic (Claude) — uses native Anthropic SDK
#    groq        — Groq (fastest inference, llama/mixtral models)
#    mistral     — Mistral AI
#    gemini      — Google Gemini (via OpenAI-compatible endpoint)
#    together    — Together AI (llama, qwen, etc.)
#    fireworks   — Fireworks AI
#    perplexity  — Perplexity AI
#    deepseek    — DeepSeek
#    xai         — xAI (Grok)
#    cohere      — Cohere
#    custom      — any OpenAI-compatible API (set HELIX_CASE_AI_BASE_URL too)
#
HELIX_CASE_AI_PROVIDER=ollama
HELIX_CASE_AI_API_KEY=
HELIX_CASE_AI_MODEL=
HELIX_CASE_AI_EMBED_MODEL=
HELIX_CASE_AI_BASE_URL=
#
# Examples:
#   Groq:    PROVIDER=groq   API_KEY=gsk_xxx  MODEL=llama-3.1-70b-versatile
#   Gemini:  PROVIDER=gemini API_KEY=xxx      MODEL=gemini-1.5-flash
#   Mistral: PROVIDER=mistral API_KEY=xxx     MODEL=mistral-large-latest
#   Custom:  PROVIDER=custom  API_KEY=xxx     MODEL=my-model  BASE_URL=https://my-server/v1
#
# ══════════════════════════════════════════════════════════════════
#  LEGACY vars — still work, used as fallback when PROVIDER is not set
# ══════════════════════════════════════════════════════════════════
HELIX_CASE_AI_BACKEND=ollama

# --- Ollama (default — runs locally via Docker, no API key needed) ---
# To use a custom GGUF model: place the .gguf file in the repo-root models/ folder,
# then set HELIX_CASE_AI_OLLAMA_MODEL to the filename without extension.
# Example: models/mistral-7b-q4.gguf  →  HELIX_CASE_AI_OLLAMA_MODEL=mistral-7b-q4
HELIX_CASE_AI_OLLAMA_URL=http://localhost:11434
HELIX_CASE_AI_OLLAMA_MODEL=llama3.2
HELIX_CASE_AI_OLLAMA_EMBED_MODEL=nomic-embed-text

# --- OpenAI ---
HELIX_CASE_AI_OPENAI_API_KEY=
HELIX_CASE_AI_OPENAI_MODEL=gpt-4o-mini
HELIX_CASE_AI_OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Anthropic ---
HELIX_CASE_AI_ANTHROPIC_API_KEY=
HELIX_CASE_AI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Push Notifications (P27) ──────────────────────────────────────────
# FCM (Firebase Cloud Messaging — Android)
# FCM_SERVICE_ACCOUNT_JSON_PATH=/path/to/firebase-service-account.json
# FCM_SERVICE_ACCOUNT_JSON_CONTENT={}   # alternative: inline JSON

# APNs (Apple Push Notification service — iOS)
# APNS_KEY_PEM=-----BEGIN PRIVATE KEY-----...
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.example.helix
# APNS_SANDBOX=true

# Web Push (VAPID)
# VAPID_PRIVATE_KEY=<base64url DER>
# VAPID_PUBLIC_KEY=<base64url DER>
# VAPID_SUBJECT=mailto:admin@example.com

# ── Email (P25) ───────────────────────────────────────────────────────
# HELIX_CASE_SMTP_HOST=localhost
# HELIX_CASE_SMTP_PORT=1025
